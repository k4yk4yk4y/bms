<% content_for :title, "Bonus Templates" %>

<div class="container-fluid">
  <div class="row">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">
          <i class="fas fa-layer-group"></i> Bonus Templates
        </h1>
        <% if can?(:create, BonusTemplate) %>
          <%= link_to new_settings_template_path, class: "btn btn-primary" do %>
            <i class="fas fa-plus"></i> New Template
          <% end %>
        <% end %>
      </div>

      <!-- Filters -->
      <div class="card mb-4">
        <div class="card-body">
          <%= form_with url: settings_templates_path, method: :get, local: true do |form| %>
            <div class="row g-3">
              <div class="col-md-3">
                <label class="form-label">Project</label>
                <%= form.select :project,
                                options_for_select([ [ "All Projects", "" ] ] + @projects.map { |project| [ project, project ] }, params[:project]),
                                {},
                                class: "form-select" %>
              </div>
              <div class="col-md-3">
                <label class="form-label">DSL Tag</label>
                <%= form.select :dsl_tag,
                                options_for_select([ [ "All DSL Tags", "" ] ] + @dsl_tags.map { |dsl_tag| [ dsl_tag, dsl_tag ] }, params[:dsl_tag]),
                                {},
                                class: "form-select" %>
              </div>
              <div class="col-md-3">
                <label class="form-label">Event</label>
                <%= form.select :event,
                                options_for_select([ [ "All Events", "" ] ] + BonusTemplate::EVENT_TYPES.map { |event| [ event.humanize, event ] }, params[:event]),
                                {},
                                class: "form-select" %>
              </div>
              <div class="col-md-3 d-flex align-items-end gap-2">
                <%= form.submit "Apply", class: "btn btn-primary" %>
                <%= link_to "Clear Filters", settings_templates_path, class: "btn btn-outline-secondary" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Templates Table -->
      <div class="card">
        <div class="card-body">
          <div class="mb-3 text-muted">
            Found: <%= @total_templates %>
            <% if @total_pages.to_i > 1 %>
              | Page <%= @current_page %> of <%= @total_pages %>
            <% end %>
          </div>
          <% if @bonus_templates.any? %>
            <div class="table-responsive">
              <table class="table table-striped table-hover">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>DSL Tag</th>
                    <th>Project</th>
                    <th>Event</th>
                    <th>Currency</th>
                    <th>Min Deposits</th>
                    <th>Wager</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% @bonus_templates.each do |template| %>
                    <tr>
                      <td>
                        <strong><%= template.name %></strong>
                        <% if template.description.present? %>
                          <br><small class="text-muted"><%= truncate(template.description, length: 50) %></small>
                        <% end %>
                      </td>
                      <td><span class="badge bg-info"><%= template.dsl_tag %></span></td>
                      <td>
                        <% if template.project == 'All' %>
                          <span class="badge bg-success" title="Applies to all projects">All Projects</span>
                        <% else %>
                          <span class="badge bg-secondary"><%= template.project %></span>
                        <% end %>
                      </td>
                      <td><span class="badge bg-primary"><%= template.event.humanize %></span></td>
                      <td><%= template.formatted_currencies || "All currencies" %></td>
                      <td><%= template.has_minimum_deposit_requirements? ? "Yes" : "No" %></td>
                      <td><%= template.wager || "N/A" %></td>
                      <td>
                        <div class="btn-group" role="group">
                          <%= link_to settings_template_path(template), class: "btn btn-sm btn-outline-primary", title: "View" do %>
                            <i class="fas fa-eye"></i>
                          <% end %>
                          <% if can?(:update, template) %>
                            <%= link_to edit_settings_template_path(template), class: "btn btn-sm btn-outline-warning", title: "Edit" do %>
                              <i class="fas fa-edit"></i>
                            <% end %>
                          <% end %>
                          <% if can?(:destroy, template) %>
                            <%= button_to settings_template_path(template), 
                                method: :delete, 
                                data: { confirm: "Are you sure you want to delete this template?" },
                                class: "btn btn-sm btn-outline-danger", 
                                title: "Delete",
                                form: { style: "display: inline;" } do %>
                              <i class="fas fa-trash"></i>
                            <% end %>
                          <% end %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
            <% if @total_pages.to_i > 1 %>
              <div class="d-flex justify-content-between align-items-center mt-3">
                <div class="text-muted small">
                  Showing <%= [(@current_page - 1) * 50 + 1, @total_templates].min %> -
                  <%= [@current_page * 50, @total_templates].min %> of <%= @total_templates %>
                </div>
                <div class="btn-group btn-group-sm">
                  <% prev_page = @current_page - 1 %>
                  <% next_page = @current_page + 1 %>
                  <% base_params = params.permit(:project, :dsl_tag, :event) %>
                  <% if @current_page > 1 %>
                    <%= link_to "Previous", settings_templates_path(base_params.merge(page: prev_page)), class: "btn btn-outline-primary" %>
                  <% else %>
                    <button class="btn btn-outline-secondary" disabled>Previous</button>
                  <% end %>
                  <% if @current_page < @total_pages %>
                    <%= link_to "Next", settings_templates_path(base_params.merge(page: next_page)), class: "btn btn-outline-primary" %>
                  <% else %>
                    <button class="btn btn-outline-secondary" disabled>Next</button>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% else %>
            <div class="text-center py-5">
              <i class="fas fa-layer-group fa-3x text-muted mb-3"></i>
              <h4 class="text-muted">No templates found</h4>
              <p class="text-muted">Create your first bonus template to get started.</p>
              <% if can?(:create, BonusTemplate) %>
                <%= link_to new_settings_template_path, class: "btn btn-primary" do %>
                  <i class="fas fa-plus"></i> Create Template
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
