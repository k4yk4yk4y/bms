<div class="row gy-3">
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <h6 class="card-title mb-0">Event Configuration</h6>
      </div>
      <div class="card-body">
        <dl class="row">
          <dt class="col-sm-5">Rewards Count:</dt>
          <dd class="col-sm-7"><%= bonus.all_rewards.count %></dd>
          
          <dt class="col-sm-5">Reward Types:</dt>
          <dd class="col-sm-7">
            <% if bonus.reward_types.any? %>
              <% bonus.reward_types.each do |type| %>
                <span class="badge bg-success me-1"><%= type.humanize %></span>
              <% end %>
            <% else %>
              <span class="text-muted">No rewards configured</span>
            <% end %>
          </dd>
        </dl>
      </div>
    </div>
  </div>
  
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <h6 class="card-title mb-0">Reward Details</h6>
      </div>
      <div class="card-body">
        <% if bonus.all_rewards.any? %>
          <% if bonus.bonus_rewards.any? %>
            <% bonus.bonus_rewards.each_with_index do |reward, index| %>
              <% fixed_bonus_dcopy_text = dcopy_template_for_currency_amounts(dcopy_fixed_bonus_reward_amounts(reward, bonus: bonus)) %>
              <% maximum_bonus_dcopy_text = dcopy_template_for_currency_amounts(dcopy_bonus_reward_maximum_amounts(reward)) %>
              <div class="mb-3">
                <dl class="row mb-0">
                  <dt class="col-sm-5 fw-bold">
                    <span class="badge bg-secondary me-1">#<%= index + 1 %></span>
                    Cash Bonuses:
                  </dt>
                  <dd class="col-sm-7 mb-0 small">
                    <% if reward.has_currency_amounts? %>
                      <div class="d-flex align-items-baseline gap-2">
                        <span class="text-muted flex-shrink-0"><%= reward.reward_type.humanize %>:</span>
                        <div class="d-flex flex-wrap gap-1">
                          <% reward.currency_amounts.each do |currency, amount| %>
                            <% next if amount.blank? %>
                            <span class="badge bg-light text-dark"><%= currency %>: <%= amount %></span>
                          <% end %>
                        </div>
                      </div>
                      <% if fixed_bonus_dcopy_text.present? %>
                        <div class="mt-2">
                          <button type="button"
                                  class="btn btn-sm btn-outline-secondary"
                                  data-copy-text="<%= fixed_bonus_dcopy_text %>"
                                  onclick="if (typeof copyDataTextToClipboard === 'function') { copyDataTextToClipboard(this); }">
                            DCopy
                          </button>
                        </div>
                      <% end %>
                    <% elsif reward.percentage.present? %>
                      <div class="mb-2">
                        <span class="text-muted"><%= reward.reward_type.humanize %>:</span>
                        <%= reward.formatted_amount %>
                      </div>

                      <% if reward.currency_maximum_amounts.present? %>
                        <div class="d-flex align-items-baseline gap-2">
                          <span class="text-muted flex-shrink-0">Maximum bonus amount by currency:</span>
                          <div class="d-flex flex-wrap gap-1">
                            <% reward.currency_maximum_amounts.each do |currency, amount| %>
                              <% next if amount.blank? %>
                              <span class="badge bg-light text-dark"><%= currency %>: <%= amount %></span>
                            <% end %>
                          </div>
                        </div>
                        <% if maximum_bonus_dcopy_text.present? %>
                          <div class="mt-2">
                            <button type="button"
                                    class="btn btn-sm btn-outline-secondary"
                                    data-copy-text="<%= maximum_bonus_dcopy_text %>"
                                    onclick="if (typeof copyDataTextToClipboard === 'function') { copyDataTextToClipboard(this); }">
                              DCopy
                            </button>
                          </div>
                        <% end %>
                      <% end %>
                    <% else %>
                      <span class="text-muted"><%= reward.reward_type.humanize %>:</span>
                      <%= reward.formatted_amount %>
                      <% if fixed_bonus_dcopy_text.present? %>
                        <div class="mt-2">
                          <button type="button"
                                  class="btn btn-sm btn-outline-secondary"
                                  data-copy-text="<%= fixed_bonus_dcopy_text %>"
                                  onclick="if (typeof copyDataTextToClipboard === 'function') { copyDataTextToClipboard(this); }">
                            DCopy
                          </button>
                        </div>
                      <% end %>
                    <% end %>
                  </dd>
                </dl>
              </div>
            <% end %>
          <% end %>
          
          <% if bonus.freespin_rewards.any? %>
            <% bonus.freespin_rewards.each_with_index do |reward, index| %>
              <% freespin_bet_dcopy_text = dcopy_template_for_currency_amounts(dcopy_freespin_bet_amounts(reward, bonus: bonus)) %>
              <div class="mb-3">
                <dl class="row mb-0">
                  <dt class="col-sm-5 fw-bold">
                    <span class="badge bg-secondary me-1">#<%= index + 1 %></span>
                    Free Spins:
                  </dt>
                  <dd class="col-sm-7 mb-0 small">
                    <div class="mb-2">
                      <span class="text-muted">Freespins count:</span>
                      <%= reward.spins_count %>
                    </div>

                    <% if reward.bet_level.present? %>
                      <div class="mb-2">
                        <span class="text-muted">Bet level:</span>
                        <%= reward.formatted_bet_level %>
                      </div>
                    <% end %>

                    <% if reward.has_game_restrictions? %>
                      <div class="mb-2 d-flex flex-wrap align-items-center gap-1">
                        <span class="text-muted">Games:</span>
                        <% reward.games.each do |game| %>
                          <span class="badge bg-primary"><%= game %></span>
                        <% end %>
                      </div>
                    <% end %>

                    <% if reward.has_currency_freespin_bet_levels? %>
                      <div>
                        <div class="d-flex align-items-baseline gap-2">
                          <span class="text-muted flex-shrink-0">Bet amount by currency:</span>
                          <div class="d-flex flex-wrap gap-1">
                            <% reward.currency_freespin_bet_levels.each do |currency, amount| %>
                              <span class="badge bg-light text-dark"><%= currency %>: <%= amount %></span>
                            <% end %>
                          </div>
                        </div>
                      </div>
                    <% else %>
                      <div class="text-muted">
                        Bet level not set
                      </div>
                    <% end %>

                    <% if freespin_bet_dcopy_text.present? %>
                      <div class="mt-2">
                        <button type="button"
                                class="btn btn-sm btn-outline-secondary"
                                data-copy-text="<%= freespin_bet_dcopy_text %>"
                                onclick="if (typeof copyDataTextToClipboard === 'function') { copyDataTextToClipboard(this); }">
                          DCopy
                        </button>
                      </div>
                    <% end %>
                  </dd>
                </dl>
              </div>
            <% end %>
          <% end %>
          
          <% if bonus.bonus_buy_rewards.any? %>
            <h6>Bonus Buy:</h6>
            <% bonus.bonus_buy_rewards.each_with_index do |reward, index| %>
              <div class="mb-2">
                <span class="badge bg-secondary me-1">#<%= index + 1 %></span>
                <% if reward.has_currency_buy_amounts? %>
                  <span class="text-muted">Purchase amount by currency:</span>
                  <% reward.currency_buy_amounts.each do |currency, amount| %>
                    <span class="badge bg-light text-dark"><%= currency %>: <%= amount %></span>
                  <% end %>
                <% else %>
                  Bonus purchase: <%= reward.formatted_buy_amount %>
                <% end %>
                <% if reward.multiplier.present? %>
                  (x<%= reward.multiplier %>)
                <% end %>
                <% if reward.bet_level.present? %>
                  <span class="text-muted">(Bet level: <%= reward.formatted_bet_level %>)</span>
                <% end %>
              </div>
            <% end %>
          <% end %>
          
          <% if bonus.freechip_rewards.any? %>
            <h6>Free Chips:</h6>
            <% bonus.freechip_rewards.each_with_index do |reward, index| %>
              <div class="mb-2">
                <span class="badge bg-secondary me-1">#<%= index + 1 %></span>
                Free chips: <%= reward.chips_count %> x <%= reward.formatted_chip_value %>
                <span class="text-muted">(Total: <%= reward.formatted_total_value %>)</span>
              </div>
            <% end %>
          <% end %>
          
          <% if bonus.material_prize_rewards.any? %>
            <h6>Material Prizes:</h6>
            <% bonus.material_prize_rewards.each_with_index do |reward, index| %>
              <div class="mb-2">
                <span class="badge bg-secondary me-1">#<%= index + 1 %></span>
                <strong><%= reward.prize_name %></strong>
                <% if reward.has_monetary_value? %>
                  <span class="text-muted">(<%= reward.formatted_prize_value %>)</span>
                <% end %>
              </div>
            <% end %>
          <% end %>
          
          <% if bonus.comp_point_rewards.any? %>
            <h6>Comp Points:</h6>
            <% bonus.comp_point_rewards.each_with_index do |reward, index| %>
              <div class="mb-2">
                <span class="badge bg-secondary me-1">#<%= index + 1 %></span>
                <%= reward.formatted_points_amount %>
              </div>
            <% end %>
          <% end %>
          
          <% if bonus.bonus_code_rewards.any? %>
            <h6>Bonus Codes:</h6>
            <% bonus.bonus_code_rewards.each_with_index do |reward, index| %>
              <div class="mb-2">
                <span class="badge bg-secondary me-1">#<%= index + 1 %></span>
                <strong><%= reward.title %></strong>
                <% if reward.set_bonus_code.present? %>
                  <code><%= reward.set_bonus_code %></code>
                <% end %>
              </div>
            <% end %>
          <% end %>
        <% else %>
          <p class="text-muted">No rewards configured yet.</p>
          <% if bonus.persisted? %>
            <a href="#" class="btn btn-primary btn-sm">Add Rewards</a>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>
