<!-- Currency Minimum Deposits Section -->
<div class="card mb-4" id="currency-minimum-deposits-card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h5 class="card-title mb-0">
      <i class="bi bi-currency-exchange"></i> 
      Minimum deposits by currency
    </h5>
    <div class="btn-group" role="group" aria-label="Minimum deposits actions">
      <button type="button" class="btn btn-sm btn-outline-primary"
              onclick="if (typeof calculateMinimumDepositsFromFreespins === 'function') { calculateMinimumDepositsFromFreespins(); }">
        Calculate
      </button>
      <button type="button" class="btn btn-sm btn-outline-secondary"
              onclick="if (typeof copyMinimumDepositsToClipboard === 'function') { copyMinimumDepositsToClipboard(this); }">
        Copy
      </button>
    </div>
  </div>
  <div class="card-body">
    <div id="currency-minimum-deposits-container"
         data-minimum-deposits="<%= ERB::Util.html_escape(bonus.currency_minimum_deposits.to_json) %>">
      <div class="row">
        <% available_currencies = bonus.project_currencies %>
        <% minimum_deposit_currencies = bonus.currency_minimum_deposits.present? ? bonus.currency_minimum_deposits.keys : [] %>
        <% selected_currencies = ((bonus.currencies.present? ? bonus.currencies : []) | minimum_deposit_currencies) & available_currencies %>
        <% selected_currencies = available_currencies if selected_currencies.empty? %>
        
        <% selected_currencies.each_with_index do |currency, index| %>
          <% minimum_deposit_value = bonus.currency_minimum_deposits[currency] %>
          <% display_minimum_deposit_value = minimum_deposit_value.present? && minimum_deposit_value.to_f == minimum_deposit_value.to_i ? minimum_deposit_value.to_i : minimum_deposit_value %>
          <div class="col-12 mb-2">
            <div class="input-group">
              <span class="input-group-text currency-code"><%= currency %></span>
              <%= number_field_tag "bonus[currency_minimum_deposits][#{currency}]", 
                  display_minimum_deposit_value,
                  class: "form-control currency-input",
                  step: Bonus.currency_step(currency),
                  min: 0,
                  placeholder: (Bonus.crypto_currency?(currency) ? "0.00000000" : "0.00"),
                  data: { 
                    currency: currency, 
                    precision: Bonus.currency_precision(currency),
                    "currency-validation-target": "input",
                    "currency-target": "minimumDeposit"
                  } %>
            </div>
          </div>
        <% end %>
      </div>

    </div>
    
    <!-- Dynamic update based on selected currencies -->
    <script>
      function fallbackCopyText(text) {
        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.setAttribute('readonly', '');
        textarea.style.position = 'absolute';
        textarea.style.left = '-9999px';
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        document.body.removeChild(textarea);
      }

      function minimumDepositsClipboardText(cardElement) {
        if (!cardElement) return '';

        const rows = cardElement.querySelectorAll('#currency-minimum-deposits-container .input-group');
        const lines = Array.from(rows).map(row => {
          const currency = row.querySelector('.currency-code')?.textContent?.trim();
          const amount = row.querySelector('input[name*="[currency_minimum_deposits]"]')?.value?.trim() || '';
          if (!currency) return null;
          return `${currency}\t${amount}`;
        }).filter(Boolean);

        return lines.join('\n');
      }

      async function copyMinimumDepositsToClipboard(buttonElement) {
        const cardElement = buttonElement?.closest('.card') || document.getElementById('currency-minimum-deposits-card');
        const text = minimumDepositsClipboardText(cardElement);
        if (!text) return;

        try {
          if (navigator.clipboard && window.isSecureContext) {
            await navigator.clipboard.writeText(text);
          } else {
            fallbackCopyText(text);
          }
        } catch (e) {
          fallbackCopyText(text);
        }
      }

      window.copyMinimumDepositsToClipboard = copyMinimumDepositsToClipboard;

      function parseNumericValue(value) {
        const parsed = parseFloat(value);
        return Number.isFinite(parsed) ? parsed : null;
      }

      function extractCurrencyFromMinimumDepositInputName(name) {
        if (!name) return null;
        const match = name.match(/currency_minimum_deposits(?:\]\[|\[)([^\]]+)\]/);
        return match ? match[1] : null;
      }

      function roundNiceAmount(amount) {
        if (!Number.isFinite(amount)) return null;
        const step = Math.abs(amount) >= 1000 ? 100 : 10;
        return Math.round(amount / step) * step;
      }

      function getFreespinRewardIndexes() {
        const inputs = document.querySelectorAll('input[name^="freespin_rewards"]');
        const indexes = new Set();
        inputs.forEach(input => {
          const match = input.name.match(/^freespin_rewards\[(\d+)\]/);
          if (match) {
            indexes.add(match[1]);
          }
        });
        return Array.from(indexes);
      }

      function getBonusBuyRewardIndexes() {
        const inputs = document.querySelectorAll('input[name^="bonus_buy_rewards"]');
        const indexes = new Set();
        inputs.forEach((input) => {
          const match = input.name.match(/^bonus_buy_rewards\[(\d+)\]/);
          if (match) {
            indexes.add(match[1]);
          }
        });
        return Array.from(indexes);
      }

      function addAmountToCurrencyTotals(totals, currency, amount) {
        if (!currency || !Number.isFinite(amount)) return;
        totals[currency] = (totals[currency] || 0) + amount;
      }

      function computeFreespinMinimumDepositsByCurrency() {
        const totals = {};

        getFreespinRewardIndexes().forEach(index => {
          const spins = parseNumericValue(document.querySelector(`input[name="freespin_rewards[${index}][spins_count]"]`)?.value);
          const percentage = parseNumericValue(document.querySelector(`input[name="freespin_rewards[${index}][deposit_percentage]"]`)?.value);
          if (spins === null || percentage === null) return;

          const baseBet = parseNumericValue(document.querySelector(`input[name="freespin_rewards[${index}][bet_level]"]`)?.value);
          const currencyInputs = document.querySelectorAll(`input[name^="freespin_rewards[${index}][currency_freespin_bet_levels]"]`);

          if (currencyInputs.length > 0) {
            currencyInputs.forEach(input => {
              const match = input.name.match(/currency_freespin_bet_levels\]\[([^\]]+)\]/);
              const currency = match ? match[1] : null;
              if (!currency) return;

              const betValue = parseNumericValue(input.value);
              const bet = betValue !== null ? betValue : 0;

              const amount = bet * spins * (percentage / 100.0);
              addAmountToCurrencyTotals(totals, currency, amount);
            });
          } else {
            const bet = baseBet !== null ? baseBet : 0;
            const minDepositInputs = document.querySelectorAll('input[name^="bonus[currency_minimum_deposits]"]');
            minDepositInputs.forEach(input => {
              const currency = extractCurrencyFromMinimumDepositInputName(input.name);
              if (!currency) return;

              const amount = bet * spins * (percentage / 100.0);
              addAmountToCurrencyTotals(totals, currency, amount);
            });
          }
        });

        getBonusBuyRewardIndexes().forEach((index) => {
          const percentage = parseNumericValue(document.querySelector(`input[name="bonus_buy_rewards[${index}][deposit_percentage]"]`)?.value);
          if (percentage === null) return;

          const amountInputs = document.querySelectorAll(`input[name^="bonus_buy_rewards[${index}][currency_buy_amounts]"]`);
          if (amountInputs.length > 0) {
            amountInputs.forEach((input) => {
              const match = input.name.match(/currency_buy_amounts\]\[([^\]]+)\]/);
              const currency = match ? match[1] : null;
              if (!currency) return;

              const buyAmount = parseNumericValue(input.value);
              if (buyAmount === null) return;

              const amount = buyAmount * (percentage / 100.0);
              addAmountToCurrencyTotals(totals, currency, amount);
            });
            return;
          }

          // Backward compatibility for old single-value field.
          const fallbackBuyAmount = parseNumericValue(document.querySelector(`input[name="bonus_buy_rewards[${index}][buy_amount]"]`)?.value);
          if (fallbackBuyAmount === null) return;

          const minDepositInputs = document.querySelectorAll('input[name^="bonus[currency_minimum_deposits]"]');
          minDepositInputs.forEach((input) => {
            const currency = extractCurrencyFromMinimumDepositInputName(input.name);
            if (!currency) return;

            const amount = fallbackBuyAmount * (percentage / 100.0);
            addAmountToCurrencyTotals(totals, currency, amount);
          });
        });

        return totals;
      }

      function calculateMinimumDepositsFromFreespins() {
        const container = document.getElementById('currency-minimum-deposits-container');
        if (!container) return;

        const totals = computeFreespinMinimumDepositsByCurrency();
        if (Object.keys(totals).length === 0) return;
        const inputs = container.querySelectorAll('input[name^="bonus[currency_minimum_deposits]"]');
        if (!inputs.length) return;

        let savedDeposits = {};
        if (container.dataset.minimumDeposits) {
          try {
            savedDeposits = JSON.parse(container.dataset.minimumDeposits) || {};
          } catch (e) {
            savedDeposits = {};
          }
        }

        inputs.forEach(input => {
          const currency = extractCurrencyFromMinimumDepositInputName(input.name);
          if (!currency) return;

          const amount = totals[currency] === undefined ? 0 : totals[currency];
          const rounded = roundNiceAmount(amount);
          if (rounded === null) return;
          const formatted = Math.trunc(rounded).toString();

          input.value = formatted;
          savedDeposits[currency] = formatted;
        });

        container.dataset.minimumDeposits = JSON.stringify(savedDeposits);
        container.dataset.minimumDepositsSeeded = 'true';
      }

      window.calculateMinimumDepositsFromFreespins = calculateMinimumDepositsFromFreespins;
      window.calculateMinimumDepositsFromRewards = calculateMinimumDepositsFromFreespins;

      // Helper function to get selected currencies from checkboxes
      function getSelectedCurrenciesMinimumDeposits() {
        const checkboxes = document.querySelectorAll('input.currency-checkbox:checked');
        return Array.from(checkboxes).map(checkbox => checkbox.value);
      }

      // Function to update currency minimum deposits fields based on selected currencies
      window.updateCurrencyMinimumDepositsFields = function() {
        const container = document.getElementById('currency-minimum-deposits-container');
        if (!container) return;
        
        const selectedCurrencies = getSelectedCurrenciesMinimumDeposits();
        const availableCurrencies = window.currentProjectCurrencies || [];
        const cryptoCurrencies = window.currentProjectCryptoCurrencies || [];
        const hasSeeded = container.dataset.minimumDepositsSeeded === 'true';
        let savedDeposits = {};
        if (container.dataset.minimumDeposits) {
          try {
            savedDeposits = JSON.parse(container.dataset.minimumDeposits) || {};
          } catch (e) {
            savedDeposits = {};
          }
        }
        
        const rowDiv = container.querySelector('.row');
        const currentCurrencies = rowDiv
          ? Array.from(rowDiv.querySelectorAll('input[type="number"]'))
              .map(input => {
                return extractCurrencyFromMinimumDepositInputName(input.name);
              })
              .filter(currency => currency !== null)
          : [];
        const savedCurrencies = hasSeeded ? [] : Object.keys(savedDeposits || {});

        // Prefer selected currencies, but keep any existing fields to avoid dropping saved values
        let displayCurrencies;
        if (selectedCurrencies.length > 0) {
          displayCurrencies = Array.from(new Set([ ...selectedCurrencies, ...currentCurrencies, ...savedCurrencies ]));
        } else if (currentCurrencies.length > 0) {
          displayCurrencies = Array.from(new Set([ ...currentCurrencies, ...savedCurrencies ]));
        } else if (savedCurrencies.length > 0) {
          displayCurrencies = savedCurrencies;
        } else {
          displayCurrencies = availableCurrencies;
        }

        // Check if update is actually needed by comparing current displayed currencies
        if (rowDiv) {
          if (currentCurrencies.length === displayCurrencies.length &&
              currentCurrencies.every(currency => displayCurrencies.includes(currency))) {
            return; // No update needed
          }
        }
        
        // Rebuild the fields
        if (!rowDiv) return;
        
        // Save ALL current values to preserve user input
        const currentValues = hasSeeded ? {} : { ...savedDeposits };
        rowDiv.querySelectorAll('input[type="number"]').forEach(input => {
          const currency = extractCurrencyFromMinimumDepositInputName(input.name);
          if (currency) {
            // Save value even if it's being edited or just typed
            const rawValue = input.value;
            const value = hasSeeded ? rawValue : (rawValue || input.getAttribute('value') || '');
            if (hasSeeded) {
              currentValues[currency] = rawValue;
            } else if (value !== '') {
              currentValues[currency] = value;
            }
          }
        });
        
        // Clear and rebuild
        rowDiv.innerHTML = '';
        
        displayCurrencies.forEach(currency => {
          const colDiv = document.createElement('div');
          colDiv.className = 'col-12 mb-2';
          
          const isCrypto = cryptoCurrencies.includes(currency);
          const step = isCrypto ? '0.00000001' : '0.01';
          const placeholder = isCrypto ? '0.00000000' : '0.00';
          const precision = isCrypto ? 8 : 2;
          
          // Only use current value if currency is still selected
          // Always use current value if it exists to preserve user input
          const currentValue = currentValues[currency] || '';
          
          colDiv.innerHTML = `
            <div class="input-group">
              <span class="input-group-text currency-code">${currency}</span>
              <input type="number" 
                     name="bonus[currency_minimum_deposits][${currency}]" 
                     value="${currentValue}"
                     class="form-control currency-input" 
                     step="${step}" 
                     min="0"
                     placeholder="${placeholder}"
                     data-currency="${currency}"
                     data-precision="${precision}"
                     data-currency-validation-target="input"
                     data-currency-target="minimumDeposit">
            </div>
          `;
          
          rowDiv.appendChild(colDiv);
        });

        container.dataset.minimumDeposits = JSON.stringify(currentValues);
        container.dataset.minimumDepositsSeeded = 'true';

      };
      
      // Note: Event listeners for currency checkboxes are handled globally
    </script>
  </div>
</div>
