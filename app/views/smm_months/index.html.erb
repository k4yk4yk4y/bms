<div class="container-fluid smm-page">
  <div class="row g-4">
    <div class="col-lg-3">
      <div class="d-grid gap-2 mb-4">
        <% if can?(:create, SmmMonth) %>
          <button type="button" class="btn btn-dark" data-bs-toggle="modal" data-bs-target="#newMonthModal">
            + NEW MONTH
          </button>
          <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#copyMonthModal" <%= "disabled" unless @current_month %>>
            COPY MONTH
          </button>
        <% end %>
      </div>

      <div class="smm-month-list list-group">
        <% @smm_months.each do |month| %>
          <%= link_to smm_months_path(month_id: month.id),
                      class: "list-group-item list-group-item-action #{'active' if @current_month&.id == month.id}" do %>
            <%= month.display_name %>
          <% end %>
        <% end %>
        <% if @smm_months.empty? %>
          <div class="list-group-item text-muted">No months yet.</div>
        <% end %>
      </div>
    </div>

    <div class="col-lg-9">
      <div class="d-flex flex-wrap justify-content-between align-items-start mb-4 gap-3">
        <div>
          <h1 class="h3 mb-1"><%= @current_month ? "#{@current_month.display_name} Campaigns" : "SMM Campaigns" %></h1>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <% if can?(:create, SmmPreset) %>
            <button type="button" class="btn btn-outline-dark" data-bs-toggle="modal" data-bs-target="#newPresetModal" <%= "disabled" unless @current_month_project %>>
              + NEW PRESET
            </button>
          <% end %>
          <% if can?(:create, SmmBonus) %>
            <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#batchCreatorModal" <%= "disabled" unless @current_month_project %>>
              + MASS CREATE BY TEMPLATE
            </button>
          <% end %>
          <% if can?(:destroy, SmmMonth) && @current_month %>
            <%= button_to "Delete Month",
                          smm_month_path(@current_month),
                          method: :delete,
                          data: { confirm: "Delete this month and all its projects?" },
                          class: "btn btn-outline-danger",
                          form: { class: "d-inline", data: { turbo: false } } %>
          <% end %>
        </div>
      </div>

      <% if @current_month %>
        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
          <div class="dropdown" data-controller="smm-project-dropdown">
            <button class="btn btn-outline-secondary dropdown-toggle"
                    type="button"
                    aria-expanded="false"
                    data-smm-project-dropdown-target="button"
                    data-action="click->smm-project-dropdown#toggle keydown->smm-project-dropdown#keydown">
              <%= @current_month_project&.display_name || "Select project" %>
            </button>
            <ul class="dropdown-menu" data-smm-project-dropdown-target="menu">
              <% @month_projects.each do |month_project| %>
                <li>
                  <%= link_to month_project.display_name,
                              smm_months_path(month_id: @current_month.id, month_project_id: month_project.id),
                              class: "dropdown-item #{'active' if @current_month_project&.id == month_project.id}" %>
                </li>
              <% end %>
              <% if @month_projects.empty? %>
                <li><span class="dropdown-item-text text-muted">No projects yet</span></li>
              <% end %>
            </ul>
          </div>
          <% if can?(:create, SmmMonthProject) %>
            <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#addProjectModal" <%= "disabled" if @available_projects.empty? %>>
              + PROJECT
            </button>
          <% end %>
          <% if can?(:destroy, SmmMonthProject) && @current_month_project %>
            <%= button_to "Remove Project",
                          smm_month_smm_month_project_path(@current_month, @current_month_project),
                          method: :delete,
                          data: { confirm: "Remove this project from the month?" },
                          class: "btn btn-outline-danger",
                          form: { class: "d-inline", data: { turbo: false } } %>
          <% end %>
        </div>

        <% if @current_month_project %>
          <div class="card">
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover align-middle smm-table mb-0">
                  <thead>
                    <tr>
                      <th>Status</th>
                      <th>Code</th>
                      <th>Deposit</th>
                      <th>Limit</th>
                      <th>Game</th>
                      <th>FS</th>
                      <th>Bet</th>
                      <th>Wager</th>
                      <th>Group</th>
                      <th>Bonus</th>
                      <th class="text-end">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if can?(:create, SmmBonus) %>
                      <% new_form_id = "smm_bonus_new_#{@current_month_project.id}" %>
                      <%= form_with scope: :smm_bonus,
                                    url: smm_month_smm_bonuses_path(@current_month),
                                    method: :post,
                                    local: true,
                                    data: { turbo: false },
                                    html: { id: new_form_id, class: "d-none" } do |form| %>
                        <%= form.hidden_field :smm_month_project_id, value: @current_month_project.id %>
                      <% end %>
                      <tr class="table-light">
                        <td>
                          <%= select_tag "smm_bonus[status]",
                                         options_for_select(SmmBonus::STATUSES.map { |key, label| [ label, key ] }, "draft"),
                                         class: "form-select form-select-sm",
                                         form: new_form_id %>
                        </td>
                        <td><%= text_field_tag "smm_bonus[code]", nil, class: "form-control form-control-sm", placeholder: "Code", form: new_form_id %></td>
                        <td><%= text_field_tag "smm_bonus[deposit]", nil, class: "form-control form-control-sm", placeholder: "-", form: new_form_id %></td>
                        <td><%= number_field_tag "smm_bonus[activation_limit]", nil, class: "form-control form-control-sm", placeholder: "Unlimited", min: 0, form: new_form_id %></td>
                        <td><%= text_field_tag "smm_bonus[game]", nil, class: "form-control form-control-sm", placeholder: "Game", form: new_form_id %></td>
                        <td><%= number_field_tag "smm_bonus[fs_count]", nil, class: "form-control form-control-sm", placeholder: "FS", min: 0, form: new_form_id %></td>
                        <td><%= text_field_tag "smm_bonus[bet_value]", nil, class: "form-control form-control-sm", placeholder: "Bet", form: new_form_id %></td>
                        <td><%= number_field_tag "smm_bonus[wager_multiplier]", nil, class: "form-control form-control-sm", placeholder: "x", form: new_form_id %></td>
                        <td>
                          <%= select_tag "smm_bonus[group]",
                                         options_for_select(SmmPreset::GROUPS.map { |key, label| [ label, key ] }),
                                         include_blank: "Group",
                                         class: "form-select form-select-sm",
                                         form: new_form_id %>
                        </td>
                        <td>
                          <div data-controller="bonus-autocomplete"
                               data-bonus-autocomplete-url-value="<%= bonuses_smm_month_smm_month_project_path(@current_month, @current_month_project) %>">
                            <input type="text"
                                   class="form-control form-control-sm mb-1"
                                   placeholder="Search bonus"
                                   data-bonus-autocomplete-target="input"
                                   data-action="input->bonus-autocomplete#search">
                            <%= select_tag "smm_bonus[bonus_id]", "",
                                           include_blank: "Select",
                                           class: "form-select form-select-sm",
                                           form: new_form_id,
                                           data: { bonus_autocomplete_target: "select" } %>
                          </div>
                        </td>
                        <td class="text-end">
                          <%= submit_tag "Add", class: "btn btn-sm btn-primary", form: new_form_id %>
                        </td>
                      </tr>
                    <% end %>

                    <% @smm_bonuses.each do |bonus| %>
                      <% row_form_id = "smm_bonus_#{bonus.id}" %>
                      <%= form_with model: bonus,
                                    url: smm_month_smm_bonus_path(@current_month, bonus),
                                    method: :patch,
                                    local: true,
                                    data: { turbo: false },
                                    html: { id: row_form_id, class: "d-none" } do %>
                      <% end %>
                      <tr class="smm-row smm-row--<%= bonus.status %>">
                        <td>
                          <%= select_tag "smm_bonus[status]",
                                         options_for_select(SmmBonus::STATUSES.map { |key, label| [ label, key ] }, bonus.status),
                                         class: "form-select form-select-sm",
                                         form: row_form_id %>
                        </td>
                        <td><%= text_field_tag "smm_bonus[code]", bonus.code, class: "form-control form-control-sm", form: row_form_id %></td>
                        <td><%= text_field_tag "smm_bonus[deposit]", bonus.deposit, class: "form-control form-control-sm", placeholder: "-", form: row_form_id %></td>
                        <td><%= number_field_tag "smm_bonus[activation_limit]", bonus.activation_limit, class: "form-control form-control-sm", placeholder: "Unlimited", min: 0, form: row_form_id %></td>
                        <td><%= text_field_tag "smm_bonus[game]", bonus.game, class: "form-control form-control-sm", form: row_form_id %></td>
                        <td><%= number_field_tag "smm_bonus[fs_count]", bonus.fs_count, class: "form-control form-control-sm", min: 0, form: row_form_id %></td>
                        <td><%= text_field_tag "smm_bonus[bet_value]", bonus.bet_value, class: "form-control form-control-sm", form: row_form_id %></td>
                        <td><%= number_field_tag "smm_bonus[wager_multiplier]", bonus.wager_multiplier, class: "form-control form-control-sm", form: row_form_id %></td>
                        <td>
                          <%= select_tag "smm_bonus[group]",
                                         options_for_select(SmmPreset::GROUPS.map { |key, label| [ label, key ] }, bonus.group),
                                         include_blank: "Group",
                                         class: "form-select form-select-sm",
                                         form: row_form_id %>
                        </td>
                        <td>
                          <div data-controller="bonus-autocomplete"
                               data-bonus-autocomplete-url-value="<%= bonuses_smm_month_smm_month_project_path(@current_month, @current_month_project) %>">
                            <input type="text"
                                   class="form-control form-control-sm mb-1"
                                   placeholder="Search bonus"
                                   data-bonus-autocomplete-target="input"
                                   data-action="input->bonus-autocomplete#search">
                            <% bonus_options = [] %>
                            <% if bonus.bonus.present? %>
                              <% label = bonus.bonus.name.presence || "Bonus ##{bonus.bonus.id}" %>
                              <% label = bonus.bonus.code.present? ? "#{label} (#{bonus.bonus.code})" : label %>
                              <% bonus_options = [ [ label, bonus.bonus.id ] ] %>
                            <% end %>
                            <%= select_tag "smm_bonus[bonus_id]",
                                           options_for_select(bonus_options, bonus.bonus_id),
                                           include_blank: "Select",
                                           class: "form-select form-select-sm",
                                           form: row_form_id,
                                           data: { bonus_autocomplete_target: "select" } %>
                          </div>
                          <% if bonus.bonus %>
                            <div class="mt-1">
                              <%= link_to "Open", bonus_path(bonus.bonus), class: "smm-bonus-link", target: "_blank" %>
                            </div>
                          <% end %>
                        </td>
                        <td class="text-end">
                          <div class="d-flex justify-content-end gap-1">
                            <%= submit_tag "Save", class: "btn btn-sm btn-outline-primary", form: row_form_id %>
                            <% if can?(:destroy, bonus) %>
                              <%= button_to "Delete",
                                            smm_month_smm_bonus_path(@current_month, bonus),
                                            method: :delete,
                                            data: { confirm: "Delete bonus row?" },
                                            class: "btn btn-sm btn-outline-danger",
                                            form: { class: "d-inline", data: { turbo: false } } %>
                            <% end %>
                          </div>
                        </td>
                      </tr>
                    <% end %>

                    <% if @smm_bonuses.empty? %>
                      <tr>
                        <td colspan="11" class="text-center text-muted py-4">No bonuses yet. Use presets or add a row.</td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        <% else %>
          <div class="alert alert-light">Select a project to view bonuses.</div>
        <% end %>
      <% else %>
        <div class="alert alert-light">Create your first month to start building SMM campaigns.</div>
      <% end %>
    </div>
  </div>
</div>

<% if can?(:create, SmmMonth) %>
  <div class="modal fade" id="newMonthModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Create New Month</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <%= form_with scope: :smm_month, url: smm_months_path, local: true, data: { turbo: false } do |form| %>
          <div class="modal-body">
            <div class="mb-3">
              <%= form.label :month, "Month", class: "form-label" %>
              <%= form.month_field :month, class: "form-control", required: true %>
            </div>
            <div class="mb-3">
              <%= form.label :name, "Display name (optional)", class: "form-label" %>
              <%= form.text_field :name, class: "form-control", placeholder: "January 2026" %>
            </div>
            <%= form.hidden_field :seed_all_projects, value: "1" %>
            <div class="form-text">Если имя не указано, будет использовано имя месяца.</div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <%= form.submit "Create", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="modal fade" id="copyMonthModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Copy Month</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <%= form_with scope: :smm_month, url: (@current_month ? copy_smm_month_path(@current_month) : "#"), local: true, data: { turbo: false } do |form| %>
          <div class="modal-body">
            <% if @current_month %>
              <div class="mb-3 text-muted">Copying from <strong><%= @current_month.display_name %></strong></div>
            <% end %>
            <div class="mb-3">
              <%= form.label :month, "New month", class: "form-label" %>
              <%= form.month_field :month, class: "form-control", required: true %>
            </div>
            <div class="mb-3">
              <%= form.label :name, "Display name (optional)", class: "form-label" %>
              <%= form.text_field :name, class: "form-control", placeholder: "February 2026" %>
            </div>
            <div class="form-text">Проекты и настройки будут перенесены, уникальные поля (код/привязанный бонус) сброшены.</div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <%= form.submit "Copy", class: "btn btn-primary", disabled: @current_month.nil? %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<% if @current_month && can?(:create, SmmMonthProject) %>
  <div class="modal fade" id="addProjectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Add Project to Month</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <%= form_with url: smm_month_smm_month_projects_path(@current_month), local: true, data: { turbo: false } do |form| %>
          <div class="modal-body">
            <div class="mb-3">
              <%= form.label :project_id, "Project", class: "form-label" %>
              <%= form.select :project_id, options_from_collection_for_select(@available_projects, :id, :name),
                              {}, class: "form-select" %>
            </div>
            <% if @available_projects.empty? %>
              <div class="text-muted">All projects are already added.</div>
            <% end %>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <%= form.submit "Add", class: "btn btn-primary", disabled: @available_projects.empty? %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<% if can?(:create, SmmPreset) %>
  <div class="modal fade" id="newPresetModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Create New SMM Preset</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <%= form_with model: @new_preset,
                      url: smm_presets_path,
                      local: true,
                      data: { turbo: false, controller: "smm-preset", "smm-preset-currencies-by-project-value": @currencies_by_project.to_json } do |form| %>
          <%= hidden_field_tag :return_month_id, @current_month&.id %>
          <div class="modal-body">
            <div class="smm-preset-section">
              <div class="smm-preset-title">PROJECT & IDENTITY</div>
              <div class="row g-3">
                <div class="col-md-4">
                  <%= form.label :project_id, "Project", class: "form-label" %>
                  <%= form.select :project_id,
                                  options_from_collection_for_select(@projects, :id, :name, @new_preset.project_id),
                                  {},
                                  class: "form-select",
                                  data: { "smm-preset-target": "project", action: "change->smm-preset#updateCurrencies" } %>
                </div>
                <div class="col-md-4">
                  <%= form.label :manager_id, "Responsible Manager", class: "form-label" %>
                  <% manager_options = @managers.map { |user| [ user.full_name.presence || user.email, user.id ] } %>
                  <%= form.select :manager_id, options_for_select(manager_options, @new_preset.manager_id),
                                  { include_blank: "Select Manager" }, class: "form-select" %>
                </div>
                <div class="col-md-4">
                  <%= form.label :subject, "Subject", class: "form-label" %>
                  <%= form.text_field :subject, class: "form-control", placeholder: "e.g. Telegram Promo" %>
                </div>
                <div class="col-md-6">
                  <%= form.label :name, "Preset Name", class: "form-label" %>
                  <%= form.text_field :name, class: "form-control" %>
                </div>
              </div>
            </div>

            <div class="smm-preset-section">
              <div class="smm-preset-title">BONUS MECHANICS</div>
              <div class="row g-3">
                <div class="col-md-4">
                  <%= form.label :bonus_type, "Bonus Type", class: "form-label" %>
                  <%= form.text_field :bonus_type, class: "form-control", placeholder: "No Deposit (Manual)" %>
                </div>
                <div class="col-md-4">
                  <%= form.label :activation_limit, "Activation Limit (Optional)", class: "form-label" %>
                  <%= form.number_field :activation_limit, class: "form-control", min: 0, placeholder: "Unlimited" %>
                </div>
                <div class="col-md-4">
                  <%= form.label :fs_count, "FS Count (Optional)", class: "form-label" %>
                  <%= form.number_field :fs_count, class: "form-control", min: 0, placeholder: "e.g. 50" %>
                </div>
              </div>
            </div>

            <div class="smm-preset-section">
              <div class="smm-preset-title">FINANCIAL RULES</div>
              <div class="row g-3">
                <div class="col-md-4">
                  <%= form.label :wager_multiplier, "Wager (multiplier)", class: "form-label" %>
                  <%= form.number_field :wager_multiplier, class: "form-control", step: 0.01, placeholder: "30" %>
                </div>
                <div class="col-md-4">
                  <%= form.label :max_win_multiplier, "Max Win (multiplier)", class: "form-label" %>
                  <%= form.number_field :max_win_multiplier, class: "form-control", step: 0.01, placeholder: "10" %>
                </div>
                <div class="col-md-4">
                  <%= form.label :locale, "Locale (ISO)", class: "form-label" %>
                  <%= form.text_field :locale, class: "form-control", placeholder: "IND" %>
                </div>
              </div>
            </div>

            <div class="smm-preset-section">
              <div class="smm-preset-title">TARGETING & CURRENCIES</div>
              <div class="row g-3">
                <div class="col-md-12">
                  <div class="form-label mb-2">Group Selection</div>
                  <div class="d-flex flex-wrap gap-4">
                    <% SmmPreset::GROUPS.each do |key, label| %>
                      <div class="form-check">
                        <%= form.radio_button :group, key, class: "form-check-input", id: "preset_group_#{key}" %>
                        <%= form.label :group, label, value: key, class: "form-check-label", for: "preset_group_#{key}" %>
                      </div>
                    <% end %>
                  </div>
                </div>
                <div class="col-md-12">
                  <div class="form-label mb-2">Available Currencies</div>
                  <div class="smm-currency-grid" data-smm-preset-target="currencies"></div>
                  <div class="form-text">Валюты соответствуют выбранному проекту.</div>
                </div>
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <%= form.submit "Save Preset", class: "btn btn-dark" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<% if @current_month_project && can?(:create, SmmBonus) %>
  <div class="modal fade" id="batchCreatorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">SMM Batch Creator</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <%= form_with url: batch_create_smm_month_smm_bonuses_path(@current_month),
                      local: true,
                      data: { turbo: false, controller: "smm-batch" } do |form| %>
          <%= hidden_field_tag :smm_month_project_id, @current_month_project.id %>
          <div class="modal-body">
            <div class="row g-3 align-items-end mb-3">
              <div class="col-md-6">
                <%= form.label :smm_preset_id, "Select Preset", class: "form-label" %>
                <%= form.select :smm_preset_id, options_from_collection_for_select(@smm_presets, :id, :name),
                                { include_blank: "Choose preset" }, class: "form-select" %>
              </div>
              <div class="col-md-2">
                <%= form.label :quantity, "Quantity", class: "form-label" %>
                <%= number_field_tag :quantity, 1, class: "form-control", min: 1, data: { "smm-batch-target": "quantity" } %>
              </div>
              <div class="col-md-4">
                <button type="button" class="btn btn-primary w-100" data-action="smm-batch#generate">Generate Rows</button>
              </div>
            </div>

            <div class="table-responsive">
              <table class="table table-sm">
                <thead>
                  <tr>
                    <th>#</th>
                    <th>Promo Code</th>
                    <th>Game Selection</th>
                    <th>Bet Value</th>
                    <th>FS Count</th>
                  </tr>
                </thead>
                <tbody data-smm-batch-target="tbody"></tbody>
              </table>
            </div>
            <div class="form-text">Поля из шаблона будут применены ко всем строкам.</div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
